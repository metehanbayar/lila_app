{
  "name": "lila-group-menu-server",
  "version": "1.0.0",
  "description": "Backend API for Lila Group Menu",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "check:syntax": "node scripts/check-syntax.js",
    "check:smoke": "node scripts/smoke-check.js",
    "check": "npm run check:syntax && npm run check:smoke",
    "images:variants": "node scripts/generate-image-variants.js",
    "audit:uploads": "node scripts/audit-uploads.js",
    "dedupe:uploads": "node scripts/dedupe-uploads.js --apply"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "fast-xml-parser": "^5.5.8",
    "helmet": "^7.1.0",
    "mssql": "^10.0.1",
    "multer": "^2.1.1",
    "node-windows": "^1.0.0-beta.8",
    "nodemailer": "^8.0.3",
    "pdf-to-printer": "^5.6.1",
    "php-unserialize": "^0.0.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3"
  }
